#include "tlpp-i18n.th"

/* ==========================================================================
   EXEMPLO 03: Arquivo de InternacionalizańŃo (i18n)
   ==========================================================================
   Este arquivo contķm as definiń§es dos metadados da documentańŃo OpenAPI 
   para o Exemplo 03, separados por idioma (BRA, EUA).
   
   A string JSON informada aqui ķ concatenada pela sintaxe de m·ltiplas linhas 
   do TLPP (ponto e vĒrgula no final). ╔ fundamental garantir que a estrutura 
   do JSON resultante seja vßlida (chaves, colchetes e vĒrgulas literais) 
   dentro do bloco de texto.
   ========================================================================== */

//////////////////////////////////////////////////////////////
TLPP TRANSLATION BRA sample_03_basic_by_id
TLPP TRANSLATION EUA sample_03_basic_by_id
//////////////////////////////////////////////////////////////

TLPP BEGIN TRANSLATION sample_03_basic_by_id

TRANSLATE 1#URI#BRA# ;
{ ;
    "title" : "DOC simples 03", ;
    "description" : "Exemplo de documentańŃo de REST utilizando i18n com ID.", ;
    "params": [ ;
        { ;
            "name": "param1", ;
            "description": "desc_param_1", ;
            "in": "query", ;
            "type": "character", ;
            "required": true ;
        } ;
    ], ;
    "responses": [ ;
        { ;
            "statusCode": 200, ;
            "description": "OK" ;
        }, ;
        { ;
            "statusCode": 400, ;
            "description": "ParŌmetro invßlido" ;
        } ;
    ] ;
}

TRANSLATE 1#URI#EUA# ;
{ ;
    "title" : "Simple DOC 03", ;
    "description" : "Example of REST documentation using i18n with ID.", ;
    "params": [ ;
        { ;
            "name": "param1", ;
            "description": "desc_param_1", ;
            "in": "query", ;
            "type": "character", ;
            "required": true ;
        } ;
    ], ;
    "responses": [ ;
        { ;
            "statusCode": 200, ;
            "description": "OK" ;
        }, ;
        { ;
            "statusCode": 400, ;
            "description": "Invalid parameter" ;
        } ;
    ] ;
}

TLPP END TRANSLATION
