#include 'tlpp-rest.th'
#include "tlpp-i18n.th"

/* ==========================================================================
   EXEMPLO 05: Descriçăo de Múltiplas Linhas (Multiline)
   ==========================================================================
   Quando há a necessidade de fornecer uma documentaçăo textual longa ou 
   detalhada para um endpoint, a limitaçăo de uma única propriedade 
   "description" na annotation pode ser contornada utilizando uma funçăo _DOC 
   (ou arquivo i18n).

   O motor de documentaçăo OpenAPI do tlppCore possui um comportamento 
   específico e sequencial para concatenar múltiplas linhas:
   
   1. Deve-se utilizar propriedades numeradas sequencialmente, iniciando 
      obrigatoriamente por "description0" ou "description1".
   2. Se vocę optar por propriedades numeradas, qualquer propriedade chamada 
      apenas "description" (sem número) será totalmente IGNORADA.
   3. A sequęncia numérica NĂO pode ter saltos. O motor interrompe a leitura 
      no primeiro número faltante, ignorando completamente as chaves seguintes.
   4. O caractere de escape "\n" ao final da string pode ser usado para 
      forçar explicitamente o salto de linha na renderizaçăo da documentaçăo.
   ========================================================================== */

@Get(endpoint="/rest/sample/doc/basic/05/multiline", description="[U_rest_sample_05_basic_DOC]")
function U_rest_sample_05_basic() as logical
    
    // Retorno vazio apenas para fins de demonstraçăo da estrutura
return oRest:setResponse('')


/* ==========================================================================
   FUNÇĂO DE DOCUMENTAÇĂO (Metadados OpenAPI)
   ==========================================================================
   Note abaixo que a propriedade "description8" foi colocada propositalmente. 
   Como a "description7" está ausente, o motor parará a leitura na linha 6 
   e a linha 8 será ignorada no documento OpenAPI final.
   ========================================================================== */
function U_rest_sample_05_basic_DOC() as character

    local cJson := '' as character

    TOSTRING cJson#;
    { ;
        "title" : "Múltiplas linhas", ;
        "description1" : "Linha 1", ;
        "description2" : "", ;
        "description3" : "Linha 2\n", ;
        "description4" : "Linha 3\n", ;
        "description5" : "...\n", ;
        "description6" : "Linha N", ;
        "description8" : "Será ignorado devido ŕ quebra de sequęncia numérica" ;
    }

return cJson
