#include "tlpp-core.th"

/* ==========================================================================
   AMARRAÇĂO DE DOCUMENTAÇĂO DINÂMICA
   ==========================================================================
   Esta funçăo é informada como parâmetro opcional na chamada da funçăo 
   tlpp.doc.generate() (vista no arquivo /src/main.tlpp).
   
   Sua responsabilidade é retornar um objeto do tipo tlpp.doc.List() para 
   indicar ao motor do OpenAPI qual funçăo _DOC está associada a qual 
   rota/método dinâmico levantado pelo servidor.
   ========================================================================== */
function U_ListDOCFunctions() as object

    local jMod     as json
    local oDoc     as object
    local lVersion := .F. as logical

    // Proteçăo de código para evitar instanciar uma classe que năo exista no tlpp.rpo
    jMod := jsonObject():New()
    if ( tlpp.module("DOC", @jMod) )
        if ( jMod['linked'] )
            lVersion := ( jMod["version"] == "doc:16b77c0d32" )
        endif
    endif

    if ( lVersion )
        oDoc := tlpp.doc.List():New()
        
        // ----------------------------------------------------------------------
        // Sintaxe de Inclusăo:
        // oDoc:add( <endpoint>, <method>, <DOC_funcion_name> )
        // ----------------------------------------------------------------------
        // <endpoint>: Rota REST (string). Ex: "/init/dyn"
        // <method>: Verbo HTTP (string). Ex: "GET", "POST", "PUT", "DELETE"
        // <DOC_funcion_name>: Nome da funçăo TLPP que contém o JSON (string).
        // ----------------------------------------------------------------------

        oDoc:add( "/init/dyn", "GET", "U_FUNC_DYN_GET_DOC" )
        oDoc:add( "/init/dyn", "PUT", "U_FUNC_DYN_PUT_DOC" )
        oDoc:add( "/class/:param1", "GET", "U_CLASS_DYN_GET_DOC" )
    endif

return oDoc
