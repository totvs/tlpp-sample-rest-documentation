#include "tlpp-i18n.th"

/* DOC: /init/dyn | MÕtodo: GET */
function U_FUNC_DYN_GET_DOC() as character
    local jDoc := JsonObject():New()
    local jResp := JsonObject():New()

    jDoc['title'] := "Exemplo 01 dinãmico"
    jDoc['description'] := "DocumentaÓÐo do endpoint [/init/dyn] mÕtodo [GET] gerado dinamicamente."
    
    jResp['statusCode'] := 200
    jResp['description'] := "Sucesso | Content: [FUNC_DYN hh:mm:ss]"
    jDoc['responses'] := { jResp }

return jDoc:toJson()


