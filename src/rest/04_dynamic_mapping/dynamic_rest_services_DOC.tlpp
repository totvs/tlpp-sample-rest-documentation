/* DOC: /class/:param1 | MÕtodo: GET */
function U_CLASS_DYN_GET_DOC() as character
    local jDoc := JsonObject():New()
    local jParam := JsonObject():New()
    local jResp := JsonObject():New()

    jDoc['title'] := "Exemplo 03 dinãmico"
    jDoc['description'] := "DocumentaÓÐo do endpoint [/class/:param1] mÕtodo [GET] recebendo 1 PathParam."

    jParam['name'] := "param1"
    jParam['description'] := "Parãmetro param1 recebido via Path Param."
    jParam['in'] := "path"
    jParam['required'] := .T.
    jParam['type'] := "character"
    jDoc['params'] := { jParam }

    jResp['statusCode'] := 200
    jResp['description'] := "Sucesso | Content: [METHOD_DYN hh:mm:ss [{param1:value_param}]]"
    jDoc['responses'] := { jResp }

return jDoc:toJson()
