#include "tlpp-i18n.th"

/* ==========================================================================
   DOC: /init/dyn | Mķtodo: GET
   ========================================================================== */
function U_FUNC_DYN_GET_DOC() as character

    local cJson := '' as character

    TOSTRING cJson#;
    { ;
        "title" : "Exemplo 01 dinŌmico", ;
        "description" : "DocumentańŃo do endpoint [/init/dyn] mķtodo [GET] gerado dinamicamente sem annotation.", ;
        "responses" : [ ;
            { ;
                "statusCode" : 200, ;
                "description" : "Sucesso | Content: [FUNC_DYN hh:mm:ss]" ;
            } ;
        ] ;
    }

return cJson

