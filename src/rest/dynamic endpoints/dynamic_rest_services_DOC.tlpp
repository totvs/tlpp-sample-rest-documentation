/* ==========================================================================
   DOC: /class/:param1 | Mķtodo: GET
   ========================================================================== */
function U_CLASS_DYN_GET_DOC() as character

    local cJson := '' as character

    TOSTRING cJson#;
    { ;
        "title" : "Exemplo 03 dinŌmico", ;
        "description" : "DocumentańŃo do endpoint [/class/:param1] mķtodo [GET] gerado dinamicamente sem annotation e recebendo 1 PathParam.", ;
        "params" : [ ;
            { ;
                "name" : "param1", ;
                "description" : "ParŌmetro param1 recebido via Path Param.", ;
                "in" : "path", ;
                "required" : true, ;
                "type" : "character" ;
            } ;
        ], ;
        "responses" : [ ;
            { ;
                "statusCode" : 200, ;
                "description" : "Sucesso | Content: [METHOD_DYN hh:mm:ss [{param1:value_param}]]" ;
            } ;
        ] ;
    }

return cJson
