#include 'tlpp-rest.th'
#include 'tlpp-core.th'

/* ==========================================================================
   GERADOR DE DOCUMENTAÇĂO (Trigger Endpoint)
   ==========================================================================
   Este endpoint aciona programaticamente o motor do tlppCore para gerar 
   o arquivo de documentaçăo das APIs.

   ATENÇĂO: Embora o termo correto da especificaçăo seja "OpenAPI", a funçăo 
   nativa `tlpp.doc.generate` ainda exige o parâmetro literal 'swagger' por 
   questőes de compatibilidade com o motor.
   
   Parâmetros da funçăo tlpp.doc.generate utilizados aqui:
   1. Formato (ex: 'swagger')
   2. Nome do arquivo gerado (ex: 'api_doc')
   3. Array de portas do AppServer (ex: {8080})
   4. Array de idiomas/locales (ex: {'en-us', 'pt-br'})
   5. Funçăo customizada de lista de DOCs (opcional, ex: "U_ListDOCFunctions")
   ========================================================================== */

@Get(endpoint="/rest/sample/doc/generate", description="Gera documentaçăo OpenAPI dos RESTs na porta 8080.")
function U_rest_sample_doc_generate() as logical

    local lOk  := .T. as logical
    local cRet := ''  as character

    begin sequence
        // O parâmetro 'swagger' é mantido aqui por exigęncia do motor tlppCore
        tlpp.doc.generate('swagger', 'api_doc', {9995}, {'en-us', 'pt-br'}, "U_ListDOCFunctions")
    recover
        lOk := .F.
    end sequence

    if ( lOk )
        cRet := '{"success":true, "message":"Geraçăo da documentaçăo OpenAPI solicitada com sucesso."}'
        oRest:setStatusCode(200)
    else
        cRet := '{"success":false, "message":"Falha ao solicitar a geraçăo da documentaçăo."}'
        oRest:setStatusCode(500)
    endif

    oRest:setKeyHeaderResponse('Content-Type', 'application/json')
    
return oRest:setResponse(cRet)
